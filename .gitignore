dist/
imager-out-*/
*.efi
*.efi.zst
*.raw
*.raw.zst
*.raw.xz

# ── Intermediate build artifacts ─────────────────────────────────────────────
*.xz
*.zst
initramfs-*.xz
initramfs-*.zst
kernel-modules-*/
systemd-boot.efi

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
__MACOSX/

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Claude Code internal state ────────────────────────────────────────────────
.claude/

# ── Day-2 / cluster-ops (kept locally only, not needed for image build) ──────
manifests/ollama/
manifests/gpu/cdi-setup.yaml
manifests/gpu/device-plugin.yaml
manifests/talos/machine-patch-cdi.yaml
scripts/03-apply-config.sh
