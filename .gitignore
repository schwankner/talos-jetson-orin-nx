# ── Credentials (never commit) ───────────────────────────────────────────────
talosconfig
kubeconfig
*.key
*.crt
# NOTE: keys/signing_key.pem is intentionally NOT ignored — it's a "build time
# throw-away" key (not secret), needed to keep module signing reproducible across
# kernel extension rebuilds. Committing it prevents "unavailable key" boot failures.

# ── Build outputs (large binaries, reproduced by scripts) ────────────────────
dist/
imager-out-*/
*.efi
*.efi.zst
*.raw
*.raw.zst
*.raw.xz

# ── Intermediate build artifacts ─────────────────────────────────────────────
*.xz
*.zst
initramfs-*.xz
initramfs-*.zst
kernel-modules-*/
systemd-boot.efi

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
__MACOSX/

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Claude Code internal state ────────────────────────────────────────────────
.claude/
