# ── Credentials & secrets (never commit) ────────────────────────────────────
talosconfig
kubeconfig
*.key
*.crt

# Kernel module signing keys — generate with: ./scripts/00-setup-keys.sh
# or: make keys
keys/

# UART / serial boot logs — kept locally for debugging only
logs/

# ── Build outputs (large binaries, reproduced by scripts) ────────────────────
dist/
imager-out-*/
*.efi
*.efi.zst
*.raw
*.raw.zst
*.raw.xz

# ── Intermediate build artifacts ─────────────────────────────────────────────
*.xz
*.zst
initramfs-*.xz
initramfs-*.zst
kernel-modules-*/
systemd-boot.efi

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
__MACOSX/

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Claude Code internal state ────────────────────────────────────────────────
.claude/

# ── Day-2 / cluster-ops (kept locally only, not needed for image build) ──────
# manifests/  → not needed for building images; kept locally for cluster-ops
manifests/
# profiles/   → generated at build time by build-uki.sh; kept locally for reference
profiles/
# day-2 operational scripts (cluster setup, Ollama, CDI, etc.)
scripts/03-apply-config.sh
scripts/04-fix-nvme-boot.sh
scripts/05-bootstrap-cluster.sh
scripts/06-deploy-ollama.sh
scripts/07-install-l4t-libs.sh
scripts/08-test-nvgpu.sh
scripts/10-setup-cdi.sh

# ── Intermediate imager output directories ────────────────────────────────────
imager-out-v*/
