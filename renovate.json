{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Talos Linux on Jetson Orin NX — dependency update config.\n\nWhen Renovate opens a PR, CI runs (shellcheck + YAML validate).\nAfter CI passes, Renovate automerges to main.\nauto-tag.yaml then creates a versioned tag → release.yaml builds the full USB image.",
  "extends": [
    "config:base",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "assignees": ["schwankner"],
  "reviewers": ["schwankner"],
  "schedule": ["at any time"],
  "prCreation": "not-pending",
  "prHourlyLimit": 3,
  "prConcurrentLimit": 5,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "description": "Group all Talos stack updates (Talos + kernel + pkgs branch + LLVM)",
      "matchManagers": ["regex"],
      "matchFileNames": ["scripts/common.sh"],
      "groupName": "Talos stack",
      "groupSlug": "talos-stack",
      "labels": ["dependencies", "talos-update"],
      "automerge": true,
      "commitMessageTopic": "Talos stack"
    },
    {
      "description": "GitHub Actions — automerge all updates (pinned SHA digests preferred)",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Docker base images in Dockerfiles — require manual review",
      "matchManagers": ["dockerfile"],
      "automerge": false
    }
  ],
  "regexManagers": [
    {
      "description": "Talos version in common.sh",
      "fileMatch": ["^scripts/common\\.sh$"],
      "matchStrings": [
        "TALOS_VERSION=\"\\$\\{TALOS_VERSION:-(?<currentValue>[^}\"]+)\\}\""
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "description": "Kernel version in common.sh (tracks torvalds/linux tags)",
      "fileMatch": ["^scripts/common\\.sh$"],
      "matchStrings": [
        "KERNEL_VERSION=\"\\$\\{KERNEL_VERSION:-(?<currentValue>[^}\"]+)\\}\""
      ],
      "depNameTemplate": "torvalds/linux",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "versioningTemplate": "semver-coerced"
    },
    {
      "description": "LLVM toolchain version for nvidia-tegra-nvgpu build",
      "fileMatch": ["^scripts/common\\.sh$"],
      "matchStrings": [
        "LLVM_REV=\"\\$\\{LLVM_REV:-(?<currentValue>[^}\"]+)\\}\""
      ],
      "depNameTemplate": "siderolabs/llvm",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Talos version referenced in GitHub Actions workflows",
      "fileMatch": ["^\\.github/workflows/.+\\.ya?ml$"],
      "matchStrings": [
        "TALOS_VERSION: '(?<currentValue>[^']+)'"
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases"
    }
  ]
}
