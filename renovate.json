{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Talos Linux on Jetson Orin — dependency update config. Renovate tracks TALOS_VERSION; KERNEL_VERSION is derived automatically at build time from siderolabs/pkgs (no manual sync needed).",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "assignees": ["schwankner"],
  "reviewers": ["schwankner"],
  "schedule": ["at any time"],
  "prCreation": "not-pending",
  "prHourlyLimit": 3,
  "prConcurrentLimit": 5,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "description": "Talos — block pre-release versions (alpha/beta/rc)",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["siderolabs/talos"],
      "allowedVersions": "!/alpha|beta|rc/"
    },
    {
      "description": "Talos — patch updates only, manual review required. Minor bumps (v1.12 → v1.13) require nvgpu module compatibility testing.",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["scripts/common.sh"],
      "matchDepNames": ["siderolabs/talos"],
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "labels": ["dependencies", "talos-update"],
      "commitMessageTopic": "Talos"
    },
    {
      "description": "Talos — disable minor/major auto-updates (manual kernel compatibility check required)",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["siderolabs/talos"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "GitHub Actions — automerge all updates",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Go modules — automerge patch and minor updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Docker base images — require manual review",
      "matchManagers": ["dockerfile"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Talos version in common.sh — Renovate opens a PR when a new stable patch is released. KERNEL_VERSION is derived automatically at build time from siderolabs/pkgs, no separate tracking needed.",
      "managerFilePatterns": ["/^scripts/common\\.sh$/"],
      "matchStrings": ["TALOS_VERSION=\"\\$\\{TALOS_VERSION:-(?<currentValue>[^}\"]+)\\}\""],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "LLVM toolchain version for nvidia-tegra-nvgpu build",
      "managerFilePatterns": ["/^scripts/common\\.sh$/"],
      "matchStrings": ["LLVM_REV=\"\\$\\{LLVM_REV:-(?<currentValue>[^}\"]+)\\}\""],
      "depNameTemplate": "siderolabs/llvm",
      "datasourceTemplate": "github-releases"
    }
  ]
}
